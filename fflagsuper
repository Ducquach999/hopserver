local logBuffer    = {}
local MAX_BUF      = 100
local _print       = print
local _warn        = warn

local function log(msg, t)
    t = t or "INFO"
    if rconsoleprint then
        local pre = t=="WARN" and "⚠ " or t=="ERROR" and "✖ " or "✓ "
        rconsoleprint(string.format("[%s] %s%s\n", os.date("%H:%M:%S"), pre, tostring(msg)))
    end
    table.insert(logBuffer, {time=tick(), msg=msg, type=t})
    if #logBuffer > MAX_BUF then table.remove(logBuffer, 1) end
end

print = function(...) _print(...); log(table.concat({...}," "), "INFO") end
warn  = function(...) _warn(...);  log(table.concat({...}," "), "WARN") end

