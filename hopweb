local function toggleWheelGui()
    local gui = nil
    local guiName = nil

    for _, g in ipairs(player.PlayerGui:GetChildren()) do
        local name = g.Name:lower()
        if name:find('wheel') and not name:find('loading') and not name:find('radioactive') then
            gui = g
            guiName = g.Name
            break
        end
    end

    if not gui then
        warn('[WHEEL] Không tìm thấy wheel GUI nào!')
        return
    end

    print('[WHEEL] Found GUI:', guiName)

    local inner = gui:FindFirstChild(guiName)
    if inner then
        local closeBtn = inner:FindFirstChild('Close')
        if closeBtn then
            firesignal(closeBtn.Activated)
            print('[WHEEL] Đã close!')
            return
        end
    end

    for _, v in ipairs(gui:GetDescendants()) do
        if v.Name == 'Close' and v:IsA('GuiButton') then
            firesignal(v.Activated)
            return
        end
    end
end

