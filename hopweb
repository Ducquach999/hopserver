print('✅ Using Debris method for pet detection!')

local function getValidTargetInfo(targetName)
    local debris = workspace:FindFirstChild('Debris')
    if not debris then return nil end
    
    local lower = string.lower(targetName)
    for _, d in pairs(debris:GetDescendants()) do
        if d:IsA('TextLabel') and d.Name == "DisplayName" then
            if string.lower(d.Text or ""):find(lower) then
                local parent = d.Parent
                if parent then
                    local isFusing = false
                    for _, c in pairs(parent:GetChildren()) do
                        if c:IsA('TextLabel') and c.Name == "Stolen" and string.upper(c.Text or "") == "FUSING" then
                            isFusing = true
                            break
                        end
                    end
                    if not isFusing then
                        for _, c in pairs(parent:GetChildren()) do
                            if c:IsA('TextLabel') then
                                local n = string.lower(c.Name or "")
                                if n:find("generation") or n:find("price") then
                                    return {name = targetName, price = c.Text or "???"}
                                end
                            end
                        end
                        return {name = targetName, price = "Unknown"}
                    end
                end
            end
        end
    end
    return nil
end

local function getAllAnimals()
    local animals = {}
    local debris = workspace:FindFirstChild('Debris')
    if not debris then return animals end
    
    for _, template in pairs(debris:GetChildren()) do
        local animalOverhead = template:FindFirstChild('AnimalOverhead')
        
        if animalOverhead and (animalOverhead:IsA('SurfaceGui') or animalOverhead:IsA('BillboardGui')) then
            local displayName = nil
            local isFusing = false
            
            for _, desc in pairs(animalOverhead:GetDescendants()) do
                if desc:IsA('TextLabel') then
                    if desc.Name == "DisplayName" then
                        displayName = desc.Text
                    elseif desc.Name == "Stolen" and string.upper(desc.Text or "") == "FUSING" then
                        isFusing = true
                    end
                end
            end
            
            if displayName and displayName ~= "" and not isFusing then
                table.insert(animals, {name = displayName})
            end
        end
    end
    
    return animals
end

local function checkTargets()
    local t1, t2 = {}, {}
    local processed = {}
    
    for _, a in ipairs(getAllAnimals()) do
        local lower = string.lower(a.name or "")
        if targetDict1[lower] and not processed[lower] then
            processed[lower] = true
            local info = getValidTargetInfo(a.name)
            if info then table.insert(t1, info) end
        elseif targetDict2[lower] and not processed[lower] then
            processed[lower] = true
            local info = getValidTargetInfo(a.name)
            if info then table.insert(t2, info) end
        end
    end
    return t1, t2
end

