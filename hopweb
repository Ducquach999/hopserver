local function getOverheadInfo(animalPosition)
    local debris = Workspace:FindFirstChild('Debris')

    if not debris then
        print('[DEBUG] getOverheadInfo: No Debris folder')

        return nil, math.huge, 0
    end

    local closestOverhead = nil
    local closestDistance = math.huge

    for _, obj in ipairs(debris:GetChildren())do
        if obj.Name == 'FastOverheadTemplate' and isBasePart(obj) then
            local distance = (obj.Position - animalPosition).Magnitude

            if distance < closestDistance and distance < 10 then
                closestDistance = distance
                closestOverhead = obj
            end
        end
    end

    if not closestOverhead then
        return nil, math.huge, 0
    end

    local gui = closestOverhead:FindFirstChild('AnimalOverhead')

    if not gui then
        return nil, math.huge, 0
    end

    local displayName = gui:FindFirstChild('DisplayName')
    local priceLabel = gui:FindFirstChild('Price')
    local generationLabel = gui:FindFirstChild('Generation')
    local name = displayName and displayName.Text or ''
    local price = priceLabel and parsePrice(priceLabel.Text) or math.huge
    local generation = generationLabel and parsePrice(generationLabel.Text) or 0

    return name, price, generation
end
