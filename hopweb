                if obj.Name == 'FastOverheadTemplate' and isBasePart(obj) then
                    local distance = (obj.Position - spawn_pos).Magnitude

                    if distance < 15 then
                        local gui = obj:FindFirstChild('AnimalOverhead')

                        if gui then
                            local generation_label = gui:FindFirstChild('Generation')

                            if generation_label then
                                local gen = parsePrice(generation_label.Text) or 0

                                if gen < min_gen then
                                    min_gen = gen
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if min_gen == math.huge then
        print('[DEBUG] getMinGenerationInBase: No animals found in base, returning 0')

        return 0
    end

    print('[DEBUG] getMinGenerationInBase: Min generation in base:', min_gen)

    return min_gen
end
local function bestAffordable(plot)
    local animals = getMovingAnimals()

    if #animals == 0 then
        print('[DEBUG] bestAffordable: No animals found')

        return nil
    end

    local min_generation_in_base = getMinGenerationInBase(plot)

    print('[DEBUG] bestAffordable: Min generation in BASE:', min_generation_in_base)

    local best, best_price = nil, -1

    for _, entry in ipairs(animals)do
        local p = tonumber(entry.price) or 0
        local g = entry.generation or 0

        local cash = cashValue and parseCash(cashValue.Value)
        if g > min_generation_in_base and cash and p > 0 and p <= cash and p > best_price then
            best = entry
            best_price = p
        end
    end

    if best then
        print('[DEBUG] bestAffordable: Found', best.name, 'for', best_price, 'gen', best.generation, '(base min:', min_generation_in_base, ')')
    else
        print('[DEBUG] bestAffordable: None affordable above base min generation')
    end

    return best
end
