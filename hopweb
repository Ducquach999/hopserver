--==================================================
-- WEBSOCKET HOPPER
--==================================================
_G.StartHopper = function()
    -- Delay random 3-5s để tránh tất cả connect cùng lúc
    local delay = 3 + math.random() * 2
    task.wait(delay)

    print("🌐 StartHopper:", WS_URL)

    local socket = nil
    local alive = false
    local running = true
    local registered = false
    local attempts = 0
    local MAX_ATTEMPTS = 10

    -- Hard timeout: 3 phút không teleport → dừng
    task.delay(180, function()
        running = false
        alive = false
        if socket then pcall(function() socket:Close() end) end
        socket = nil
        print("⏰ 180s timeout, dừng hopper")
    end)

    local function send(data)
        if not alive or not socket then return false end
        return pcall(function() socket:Send(HttpService:JSONEncode(data)) end)
    end

    local function onMessage(msg)
        local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok or type(data) ~= "table" then return end

        local t = data.type

        if t == "welcome" then
            send({action = "register", username = LP.Name})

        elseif t == "registered" then
            registered = true
            send({action = "next"})

        elseif t == "job" then
            local jid = data.jobId
            if jid and jid ~= "" then
                print("🚀 Teleport →", jid)
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(data.placeId, jid, LP)
                end)
            else
                -- Server bảo chờ rồi retry
                local wait_sec = (data.seconds or 3)
                task.delay(wait_sec, function()
                    if alive then send({action = "next"}) end
                end)
            end

        elseif t == "wait" then
            local wait_sec = (data.seconds or 3)
            task.delay(wait_sec, function()
                if alive then send({action = "next"}) end
            end)

        elseif t == "pong" then
            -- ok

        end
    end

    local function connect()
        if not running then return end

        attempts = attempts + 1
        if attempts > MAX_ATTEMPTS then
            warn("❌ Đã thử " .. MAX_ATTEMPTS .. " lần, dừng hopper")
            running = false
            return
        end

        -- Đóng socket cũ nếu còn
        if socket then
            pcall(function() socket:Close() end)
            socket = nil
        end
        alive = false
        registered = false

        print(string.format("🔄 [%d/%d] Connecting...", attempts, MAX_ATTEMPTS))

        -- Chạy trong task.spawn để không block thread chính
        -- Volt cần điều này vì wsConnect() có thể hang
        task.spawn(function()
            local ok, ws = pcall(function() return wsConnect(WS_URL) end)

            if not ok or not ws or type(ws) ~= "userdata" and type(ws) ~= "table" then
                print("❌ Connect failed:", tostring(ws))
                if running then
                    task.delay(2, connect)
                end
                return
            end

            -- Volt cần 1 frame để WS object initialize xong
            task.wait()

            -- Verify object có event thật không
            if not ws.OnMessage or not ws.OnClose then
                print("❌ WS object invalid (no events)")
                pcall(function() ws:Close() end)
                if running then
                    task.delay(2, connect)
                end
                return
            end

            socket = ws
            alive = true
            attempts = 0  -- reset khi connect thành công
            print("🔗 Connected!")

            socket.OnMessage:Connect(function(msg)
                pcall(onMessage, msg)
            end)

            socket.OnClose:Connect(function()
                alive = false
                registered = false
                socket = nil
                print("🔌 Disconnected")
                if running then
                    task.delay(1, connect)
                end
            end)
        end)
    end

    -- Ping loop giữ connection sống
    task.spawn(function()
        while running do
            task.wait(15)
            if alive then send({action = "ping"}) end
        end
    end)

    connect()
end
