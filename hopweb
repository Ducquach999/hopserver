local function walkToDynamic(target, reach, timeout, jumpWhileWalking)
    reach = reach or 3
    timeout = timeout or 35

    local _, hum, hrp = ensureChar()
    if not hum or not hrp then
        print('[DEBUG] walkToDynamic: No humanoid or root part')
        return false
    end

    local t0 = tick()
    local lastPos = hrp.Position
    local lastMoveTime = tick()
    local stuckCount = 0

    while tick() - t0 < timeout do
        if not target or not target.Parent then
            print('[DEBUG] walkToDynamic: Target lost')
            return false
        end

        local pos
        if target:IsA('ProximityPrompt') then
            local att = target.Parent
            if att and att:IsA('Attachment') then
                pos = att.WorldPosition
            elseif att and att:IsA('BasePart') then
                pos = att.Position
            end
        elseif isBasePart(target) then
            pos = target.Position
        end

        if not pos then
            print('[DEBUG] walkToDynamic: No position found')
            return false
        end

        if (hrp.Position - pos).Magnitude <= reach then
            print('[DEBUG] walkToDynamic: Reached target')
            return true
        end

        pcall(function() hum:MoveTo(pos) end)

        if jumpWhileWalking then
            hum.Jump = true
        end

        local now = tick()
        local moved = (hrp.Position - lastPos).Magnitude
        if moved > 0.8 then
            lastPos = hrp.Position
            lastMoveTime = now
            stuckCount = math.max(0, stuckCount - 1)
        elseif now - lastMoveTime >= 1.5 then
            stuckCount = stuckCount + 1
            lastMoveTime = now
            print('[NAV] Stuck count:', stuckCount)
            if stuckCount <= 3 then
                pcall(function() hum.Jump = true end)
                task.wait(0.4)
            elseif stuckCount > 6 then
                print('[NAV] Respawning to unstuck...')
                stuckCount = 0
                pcall(function() hum.Health = 0 end)
                local respawned = false
                local conn = player.CharacterAdded:Connect(function() respawned = true end)
                local t0 = tick()
                while not respawned and tick() - t0 < 5 do task.wait(0.1) end
                conn:Disconnect()
                task.wait(1.5)
                _, hum, hrp = ensureChar()
                if not hum or not hrp then return false end
                lastPos = hrp.Position
                lastMoveTime = tick()
            end
        end

        task.wait(0.15 + math.random() * 0.05)
    end

    print('[DEBUG] walkToDynamic: Timeout')
    return false
end
local function firePrompt(prompt, tries)
    if not prompt or not prompt.Parent then
        print('[DEBUG] firePrompt: No prompt')

        return false
    end

    tries = tries or 3

    for _ = 1, tries do
        local ok = pcall(function()
            fireproximityprompt(prompt)
            task.wait(0.1)
        end)

        if ok then
            print('[DEBUG] firePrompt: Fired successfully')

            return true
        end

        task.wait(0.1)
    end

    print('[DEBUG] firePrompt: Failed')

    return false
end
local function parsePrice(txt)
    if not txt then
        return math.huge
    end

    local s = tostring(txt):upper():gsub('%$', ''):gsub(',', '')
    local n = tonumber((s:match('[%d%.]+'))) or 0

    if s:find('K') then
        n = n * 1000
    end
    if s:find('M') then
        n = n * 1000000
    end
    if s:find('B') then
        n = n * 1000000000
    end

    return n
end

local function parseCash(cashValue)
    if not cashValue then return 0 end
    local txt = tostring(cashValue):upper():gsub('%$', ''):gsub(',', '')
    local n = tonumber((txt:match('[%d%.]+'))) or 0
    
    if txt:find('K') then
        n = n * 1000
    end
    if txt:find('M') then
        n = n * 1000000
    end
    if txt:find('B') then
        n = n * 1000000000
    end
    
    return n
end

