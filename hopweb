_G.hopperRunning = false
_G._hopperKill = nil  -- function để kill socket từ bên ngoài

_G.StopHopper = function()
    _G.hopperRunning = false
    -- Nếu socket đang connected → đóng ngay
    if _G._hopperKill then
        _G._hopperKill()
        _G._hopperKill = nil
    end
end

_G.StartHopper = function()
    -- Nếu đang có hopper chạy, dừng cái cũ trước
    _G.hopperRunning = true

    
local delayTime = 60 + math.random() * 120

-- Sử dụng trong hàm wait (nếu bạn đang dùng Roblox hoặc môi trường tương tự)
task.wait(2)
    print(string.format("⏳ Delay %.2fs trước khi kết nối WebSocket...", delayTime))
    task.wait(delayTime)
    
    -- Kiểm tra sau delay: nếu bị cancel (StopHopper gọi) thì không connect
    if not _G.hopperRunning then
        warn("🛑 Hopper bị cancel trước khi kết nối (target found)")
        return
    end
    
    print("🌐 WebSocket Hopper Starting...")
    print("📡 Server:", WS_URL)
    
    local RECONNECT_DELAY = 2
    local PING_INTERVAL = 10
    local MAX_RECONNECT = 20  -- Tăng lên 20 để không bị dừng sớm
    
    local socket = nil
    local isConnected = false
    local lastJobId = nil
    local connectionAttempts = 0
    local stopReconnect = false
    local hopperActive = true  -- Flag tổng, set false khi 180s timeout
    
    -- Expose kill function để StopHopper có thể đóng socket từ bên ngoài
    _G._hopperKill = function()
        hopperActive = false
        stopReconnect = true
        isConnected = false
        if socket then
            pcall(function() socket:Close() end)
            socket = nil
        end
        warn("🛑 Hopper killed (target detected giữa chừng)")
    end
    
    -- Timeout 180s không chuyển server → ngắt tất cả kết nối
    task.spawn(function()
        task.wait(180)
        if hopperActive and _G.hopperRunning then
            warn("⚠️ 180s timeout - ngắt tất cả kết nối...")
            hopperActive = false
            stopReconnect = true
            if socket then
                pcall(function() socket:Close() end)
            end
            isConnected = false
            socket = nil
        end
    end)
    
    local function sendMessage(data)
        if not isConnected or not socket then return false end
        local ok = pcall(function() 
            socket:Send(HttpService:JSONEncode(data)) 
        end)
        return ok
    end
    
    local function requestNextJob()
        if isConnected then
            print("📨 Requesting next job...")
            sendMessage({action = "next"})
        end
    end
    
    local function onMessage(msg)
        print("📩 Received:", string.sub(msg, 1, 100))
        
        local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok or not data then 
            warn("❌ Failed to decode message!")
            return 
        end
        
        local t = data.type
        print("📦 Message type:", t)
        
        if t == "welcome" then
            print("✅ Connected to server! PlaceId:", data.placeId)
            connectionAttempts = 0  -- Reset khi nhận welcome thành công
            sendMessage({action = "register", username = LP.Name, userId = LP.UserId})
            
        elseif t == "registered" then
            print("✅", data.message or "Registered")
            task.delay(0.5, function()
                print("📨 First job request...")
                sendMessage({action = "next"})
            end)
            
        elseif t == "job" then
            print("🎯 Received job response!")
            if data.jobId then
                print("🎯 JobId:", data.jobId)
                if data.jobId ~= lastJobId then
                    lastJobId = data.jobId
                    print("🚀 Teleporting...")
                    -- Teleport → Roblox sẽ disconnect WS, OnClose sẽ reconnect
                    -- Không cần request next sau teleport vì script restart ở server mới
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(data.placeId, data.jobId, LP)
                    end)
                    -- Nếu teleport fail (pcall bắt được lỗi), request job tiếp
                    task.delay(3, function()
                        if isConnected then
                            print("📨 Teleport có thể failed, requesting next job...")
                            sendMessage({action = "next"})
                        end
                    end)
                else
                    print("⚠️ Same JobId, skipping → request next...")
                    task.delay(0.5, function()
                        requestNextJob()
                    end)
                end
            else
                -- jobId nil → server trả message không có job
                print("⚠️", data.message or "No job available")
                task.delay(5, function()
                    if isConnected then
                        print("📨 Retry requesting job...")
                        sendMessage({action = "next"})
                    end
                end)
            end
            
        elseif t == "wait" then
            -- ✅ FIX BUG CHÍNH: Server báo queue rỗng, chờ rồi retry
            local waitSecs = (data.seconds or 3) + 1  -- +1s buffer
            print(string.format("⏳ Server yêu cầu chờ %ds rồi retry...", waitSecs))
            task.delay(waitSecs, function()
                if isConnected then
                    print("📨 Retry after wait...")
                    sendMessage({action = "next"})
                end
            end)
            
        elseif t == "queue_refreshed" then
            print("♻️ Queue refreshed:", data.queue_size or "?")
            -- Queue có data mới → request ngay
            task.delay(0.5, function()
                if isConnected then
                    requestNextJob()
                end
            end)
            
        elseif t == "pong" then
            -- OK, ping-pong hoạt động
            
        elseif t == "status" then
            print(string.format("📊 Q=%d C=%d", data.queue or 0, data.clients or 0))
            
        elseif t == "error" then
            warn("❌ Server error:", data.message or "unknown")
            -- Retry sau lỗi
            task.delay(3, function()
                if isConnected then
                    sendMessage({action = "next"})
                end
            end)
        else
            print("❓ Unknown type:", t)
        end
    end
    
    local connectWS  -- forward declare
    
    connectWS = function()
        if stopReconnect or not hopperActive then
            warn("🛑 Hopper đã dừng, không reconnect")
            return
        end
        
        -- Đóng socket cũ
        if socket then 
            pcall(function() socket:Close() end) 
        end
        socket = nil
        isConnected = false
        
        connectionAttempts = connectionAttempts + 1
        
        if connectionAttempts > MAX_RECONNECT then
            warn("❌ Đã thử " .. MAX_RECONNECT .. " lần, dừng lại")
            return
        end
        
        print(string.format("🔄 [Attempt %d/%d] Connecting to: %s", connectionAttempts, MAX_RECONNECT, WS_URL))
        
        local connectSuccess = false
        local connectError = nil
        local receivedWelcome = false
        local onCloseRegistered = false
        
        task.spawn(function()
            local ok, ws = pcall(function()
                return wsConnect(WS_URL)
            end)
            
            if ok and ws then
                socket = ws
                isConnected = true
                connectSuccess = true
                print("🔗 WebSocket Connected!")
                
                -- OnMessage
                pcall(function()
                    if socket.OnMessage then
                        socket.OnMessage:Connect(function(msg)
                            pcall(function() 
                                if string.find(msg, '"welcome"') then
                                    receivedWelcome = true
                                end
                                onMessage(msg) 
                            end)
                        end)
                    end
                end)
                
                -- OnClose - luôn reconnect trừ khi stopReconnect
                pcall(function()
                    if socket.OnClose then
                        onCloseRegistered = true
                        socket.OnClose:Connect(function()
                            print("🔌 Disconnected! (attempt=" .. connectionAttempts .. ")")
                            isConnected = false
                            socket = nil
                            if not stopReconnect and hopperActive then
                                -- Reset attempts để reconnect không bị count sai
                                -- Giữ nguyên connectionAttempts để track số lần reconnect
                                local delay = math.min(RECONNECT_DELAY * connectionAttempts, 10)
                                print(string.format("🔄 Reconnecting in %.1fs...", delay))
                                task.wait(delay)
                                connectWS()
                            else
                                warn("🛑 Không reconnect (stopReconnect=" .. tostring(stopReconnect) .. ")")
                            end
                        end)
                    end
                end)
            else
                connectError = tostring(ws)
                print("❌ Connect failed:", connectError)
            end
        end)
        
        -- Chờ tối đa 8 giây cho connection
        local waited = 0
        while not connectSuccess and not connectError and waited < 8 do
            task.wait(0.5)
            waited = waited + 0.5
        end
        
        if not connectSuccess then
            warn("❌ Connection timeout/failed! " .. (connectError or "No response after 8s"))
            if not stopReconnect and hopperActive and connectionAttempts < MAX_RECONNECT then
                local delay = math.min(RECONNECT_DELAY * connectionAttempts, 10)
                task.wait(delay)
                return connectWS()
            end
            return
        end
        
        -- Chờ welcome tối đa 15s
        task.spawn(function()
            task.wait(15)
            if isConnected and not receivedWelcome then
                warn("⚠️ 15s không nhận welcome, reconnecting...")
                if socket then
                    pcall(function() socket:Close() end)
                end
            end
        end)
    end
    
    -- Ping loop
    task.spawn(function()
        while hopperActive do
            task.wait(PING_INTERVAL)
            if isConnected then 
                sendMessage({action = "ping"}) 
            end
        end
    end)
    
    -- Connect
    connectWS()
end

