function findFirstAncestorBasePart(instance)
    local current = instance.Parent

    while current do
        if current:IsA('BasePart') then
            return current
        end

        current = current.Parent
    end

    return nil
end
function getNearestPodium(pos, base)
    base = base or getCurrentBase()

    local Podiums = base:FindFirstChild('AnimalPodiums')

    if not Podiums then
        return nil
    end

    local nearestPodium = nil
    local shortestDistance = math.huge

    for i, v in pairs(Podiums:GetChildren())do
        local podiumPos = v.Base.Decorations.Part.Position
        local distance = (pos - podiumPos).Magnitude

        if distance < shortestDistance then
            shortestDistance = distance
            nearestPodium = v
        end
    end

    return nearestPodium and tonumber(nearestPodium.Name) or nil
end
