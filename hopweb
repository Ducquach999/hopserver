--==================================================
_G.StartHopper = function()
    -- DELAY RANDOM 4-6s TRƯỚC KHI KẾT NỐI
    local delayTime = 4 + math.random() * 2
    print(string.format("⏳ Delay %.2fs trước khi kết nối WebSocket...", delayTime))
    task.wait(delayTime)
    
    print("🌐 WebSocket Hopper Starting...")
    print("📡 Server:", WS_URL)
    
    local RECONNECT_DELAY = 1
    local PING_INTERVAL = 10
    
    local socket = nil
    local isConnected = false
    local lastJobId = nil
    local connectionAttempts = 0
    local stopReconnect = false  -- Flag để dừng reconnect
    
    -- Timeout 180s không chuyển server → ngắt tất cả kết nối
    task.spawn(function()
        task.wait(180)
        warn("⚠️ 180s timeout - ngắt tất cả kết nối...")
        stopReconnect = true  -- Dừng reconnect trước
        connectionAttempts = 999  -- Đảm bảo không reconnect
        if socket then
            pcall(function() socket:Close() end)
        end
        isConnected = false
        socket = nil
    end)
    
    local function sendMessage(data)
        if not isConnected or not socket then return false end
        local ok = pcall(function() 
            socket:Send(HttpService:JSONEncode(data)) 
        end)
        return ok
    end
    
    local function onMessage(msg)
        print("📩 Received:", string.sub(msg, 1, 100))
        
        local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok or not data then 
            warn("❌ Failed to decode message!")
            return 
        end
        
        local t = data.type
        print("📦 Message type:", t)
        
        if t == "welcome" then
            print("✅ Connected to server! PlaceId:", data.placeId)
            connectionAttempts = 0
            sendMessage({action = "register", username = LP.Name, userId = LP.UserId})
            
        elseif t == "registered" then
            print("✅", data.message)
            task.delay(0.5, function()
                print("📨 First job request...")
                sendMessage({action = "next"})
            end)
            
        elseif t == "job" then
            print("🎯 Received job response!")
            if data.jobId then
                print("🎯 JobId:", data.jobId)
                if data.jobId ~= lastJobId then
                    lastJobId = data.jobId
                    print("🚀 Teleporting...")
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(data.placeId, data.jobId, LP)
                    end)
                else
                    print("⚠️ Same JobId, skipping...")
                end
                -- Có jobId → request tiếp sau 1-1.5s
                task.delay(1 + math.random() * 0.5, function()
                    if isConnected then
                        print("📨 Requesting next job...")
                        sendMessage({action = "next"})
                    end
                end)
            else
                -- Không có jobId → request lại sau 5s
                print("⚠️", data.message or "No job available")
                task.delay(5, function()
                    if isConnected then
                        print("📨 Retry requesting job...")
                        sendMessage({action = "next"})
                    end
                end)
            end
            
        elseif t == "queue_refreshed" then
            print("♻️ Queue refreshed:", data.queue_size)
            
        elseif t == "pong" then
            -- OK
            
        elseif t == "status" then
            print(string.format("📊 Q=%d C=%d", data.queue or 0, data.clients or 0))
            
        elseif t == "error" then
            warn("❌", data.message)
        else
            print("❓ Unknown type:", t)
        end
    end
    
    local function connectWS()
        -- Đóng socket cũ
        if socket then 
            pcall(function() socket:Close() end) 
        end
        socket = nil
        isConnected = false
        
        connectionAttempts = connectionAttempts + 1
        
        -- Kiểm tra giới hạn trước khi connect
        if connectionAttempts > 10 then
            warn("❌ Đã thử 10 lần, dừng lại")
            return
        end
        
        print(string.format("🔄 [Attempt %d/10] Connecting to: %s", connectionAttempts, WS_URL))
        
        local connectSuccess = false
        local connectError = nil
        local receivedWelcome = false
        
        task.spawn(function()
            local ok, ws = pcall(function()
                return wsConnect(WS_URL)
            end)
            
            if ok and ws then
                socket = ws
                isConnected = true
                connectSuccess = true
                print("🔗 WebSocket Connected!")
                
                -- OnMessage
                pcall(function()
                    if socket.OnMessage then
                        socket.OnMessage:Connect(function(msg)
                            pcall(function() 
                                -- Check welcome
                                if string.find(msg, '"welcome"') then
                                    receivedWelcome = true
                                end
                                onMessage(msg) 
                            end)
                        end)
                    end
                end)
                
                -- OnClose - reconnect nếu chưa quá giới hạn
                pcall(function()
                    if socket.OnClose then
                        socket.OnClose:Connect(function()
                            print("🔌 Disconnected!")
                            isConnected = false
                            socket = nil
                            if connectionAttempts < 10 then
                                print("🔄 Reconnecting... (" .. connectionAttempts .. "/10)")
                                task.wait(RECONNECT_DELAY)
                                connectWS()
                            else
                                warn("❌ Đã reconnect 10 lần, dừng lại")
                            end
                        end)
                    end
                end)
            else
                connectError = tostring(ws)
            end
        end)
        
        -- Chờ tối đa 5 giây cho connection
        local waited = 0
        while not connectSuccess and not connectError and waited < 5 do
            task.wait(0.5)
            waited = waited + 0.5
        end
        
        if not connectSuccess then
            warn("❌ Connection timeout/failed!", connectError or "No response after 5s")
            if connectionAttempts < 10 then
                task.wait(RECONNECT_DELAY)
                return connectWS()
            end
            return
        end
        
        -- Chờ welcome tối đa 10s
        task.spawn(function()
            task.wait(10)
            if isConnected and not receivedWelcome then
                warn("⚠️ 10s không nhận welcome, reconnecting...")
                if socket then
                    pcall(function() socket:Close() end)
                end
            end
        end)
    end
    
    -- Ping loop
    task.spawn(function()
        while true do
            task.wait(PING_INTERVAL)
            if isConnected then 
                sendMessage({action = "ping"}) 
            end
        end
    end)
    
    -- Connect
    connectWS()
end

