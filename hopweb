            platform.CanCollide = true
            platform.Material = Enum.Material.SmoothPlastic
            platform.BrickColor = BrickColor.new("Medium stone grey")
            platform.Parent = workspace
        end
    end
    print('✅ Dọn Workspace - Deleted:', deleted)
end
