local function podiumPrompt(pod)
    local spawn = pod:FindFirstChild('Base') and pod.Base:FindFirstChild('Spawn')
    local pa = spawn and spawn:FindFirstChild('PromptAttachment')

    if pa then
        for _, p in ipairs(pa:GetChildren())do
            if p:IsA('ProximityPrompt') then
                local a = tostring(p.ActionText or ''):lower()

                if a:find('sell') then
                    return p
                end
            end
        end

        return pa:FindFirstChildOfClass('ProximityPrompt')
    end

    return nil
end
local function podiumPrice(pod)
    for _, d in ipairs(pod:GetDescendants())do
        if d.Name == 'AnimalOverhead' then
            local p = d:FindFirstChild('Price')

            if p and p:IsA('TextLabel') then
                return parsePrice(p.Text)
            end
        end
    end

    return math.huge
end
local function sellCheapest(plot)
    print('[SELL DEBUG] sellCheapest: Starting')

    local pods = plot and plot:FindFirstChild('AnimalPodiums')

    if not pods then
        print('[SELL DEBUG] sellCheapest: No AnimalPodiums folder')

        return
    end

    local pod_count = #pods:GetChildren()

    print('[SELL DEBUG] Found', pod_count, 'podiums')

    local debris = Workspace:FindFirstChild('Debris')

    if not debris then
        print('[SELL DEBUG] sellCheapest: No Debris folder')

        return
    end

    local overhead_count = 0

    for _, obj in ipairs(debris:GetChildren())do
        if obj.Name == 'FastOverheadTemplate' then
            overhead_count = overhead_count + 1
        end
    end

    print('[SELL DEBUG] Found', overhead_count, 'FastOverheadTemplate objects in Debris')

    local entries = {}

    for pod_index, pod in ipairs(pods:GetChildren())do
        local base = pod:FindFirstChild('Base')

        if not base then
            continue
        end

        local spawn = base:FindFirstChild('Spawn')

        if not spawn then
            continue
        end

        local spawn_pos = spawn.Position
        local closest_overhead = nil
        local closest_distance = math.huge

        for _, obj in ipairs(debris:GetChildren())do
            if obj.Name == 'FastOverheadTemplate' and isBasePart(obj) and not obj:FindFirstChild('CashPad') then
                local distance = (obj.Position - spawn_pos).Magnitude

                if distance < closest_distance and distance < 15 then
                    closest_distance = distance
                    closest_overhead = obj
                end
            end
        end

        if not closest_overhead then
            continue
        end

        local gui = nil

        for _, child in ipairs(closest_overhead:GetChildren())do
            if child.Name == 'AnimalOverhead' or child:IsA('BillboardGui') or child:IsA('SurfaceGui') then
                gui = child

                break
            end
        end

        if not gui then
            continue
        end

        local price_label = gui:FindFirstChild('Price')
        local display_name = gui:FindFirstChild('DisplayName')
        local generation_label = gui:FindFirstChild('Generation')

        if price_label then
            local price = parsePrice(price_label.Text)
            local generation = generation_label and parsePrice(generation_label.Text) or 0
            local name = display_name and display_name.Text or 'Unknown'
            local prompt = podiumPrompt(pod)

            if not prompt then
                continue
            end

            print('[SELL DEBUG] \u{2713} Adding podium', pod.Name, ':', name, 'Price:', price, 'Gen:', generation)
            table.insert(entries, {
                pod = pod,
                price = price,
                generation = generation,
                prompt = prompt,
                name = name,
            })
        end
    end

    print('[SELL DEBUG] Total entries collected:', #entries)

    if #entries == 0 then
        print('[SELL DEBUG] sellCheapest: No animals found in podiums')

        return
    end

    table.sort(entries, function(a, b)
        if a.generation == b.generation then
            return a.price < b.price
        end

        return a.generation < b.generation
    end)

    local lowest_generation = entries[1].generation
    local lowest_price = math.huge

    for _, e in ipairs(entries)do
        if e.generation == lowest_generation and e.price < lowest_price then
            lowest_price = e.price
        end
    end

    print('[SELL DEBUG] sellCheapest: Lowest generation:', lowest_generation, 'Lowest price in that gen:', lowest_price)

    local sold_count = 0

    for _, e in ipairs(entries)do
        if e.generation == lowest_generation and e.price == lowest_price then
            local pod_name = e.pod.Name

            if pod_name then
                print('[SELL DEBUG] Selling podium', pod_name, '-', e.name, 'Price:', e.price, 'Gen:', e.generation)
                sellBrainrot(tonumber(pod_name))

                sold_count = sold_count + 1
                totalAnimalsSold = totalAnimalsSold + 1

                task.wait(0.2)
            end
        end
    end

    print('[SELL DEBUG] sellCheapest: Sold', sold_count, 'animals')
end
local function hasRequired(plot)
    local pods = plot and plot:FindFirstChild('AnimalPodiums')

    if not pods then
        return false
    end

    local debris = Workspace:FindFirstChild('Debris')

    if not debris then
        print('[DEBUG] hasRequired: No Debris folder')

        return false
    end

    local f1, f2 = false, false

    for _, pod in ipairs(pods:GetChildren())do
        local spawn = pod:FindFirstChild('Base') and pod.Base:FindFirstChild('Spawn')

        if spawn then
            local spawn_pos = spawn.Position

            for _, obj in ipairs(debris:GetChildren())do
                if obj.Name == 'FastOverheadTemplate' and isBasePart(obj) then
                    local distance = (obj.Position - spawn_pos).Magnitude

                    if distance < 15 then
                        local gui = obj:FindFirstChild('AnimalOverhead')

                        if gui then
                            local display_name = gui:FindFirstChild('DisplayName')

                            if display_name then
                                local name = display_name.Text

                                if name == 'Trippi Troppi' then
                                    f1 = true

                                    print('[DEBUG] hasRequired: Found Trippi Troppi at podium', pod.Name)
                                end
                                if name == 'Gangster Footera' then
                                    f2 = true

                                    print('[DEBUG] hasRequired: Found Gangster Footera at podium', pod.Name)
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    print('[DEBUG] hasRequired: Trippi=', f1, 'Gangster=', f2)

    return f1 and f2
end
