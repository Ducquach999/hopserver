    for _, child in pairs(workspace:GetChildren()) do
        if child.Name ~= "Debris" and not child.Name:lower():match("plot") and child.Name ~= LP.Name then
            pcall(function()
                child:Destroy()
                deleted = deleted + 1
                if deleted % 10 == 0 then task.wait() end
