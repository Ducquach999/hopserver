local function fileContainsName(path, name)
    local ok, data = pcall(readfile, path)
    if not ok or not data then return false end
    for line in data:gmatch('[^\n]+') do
        if line:gsub('%s', '') == name then return true end
    end
    return false
end

local function appendName(path, name)
    local ok, data = pcall(readfile, path)
    local content = (ok and data and data ~= '') and (data:gsub('%s+$', '') .. '\n' .. name) or name
    pcall(writefile, path, content .. '\n')
end

