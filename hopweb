    -- Tạo bệ đứng để không rơi xuống void
    local char = LP.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local platform = Instance.new("Part")
            platform.Name = "StandPlatform"
            platform.Size = Vector3.new(10, 1, 10)
